<!--
    ════════════════════════════════════════════════════════════════════════
    EXAMPLE — WPF View for the Materials sync feature.
              Demonstrates:
                • Constructor-injected ViewModel via code-behind
                • Two-panel ListBox layout (cloud ↔ model) with transfer arrows
                • Custom DataTemplates for cloud and Revit material rows
                • Per-row delete button revealed via DataTrigger on IsSelected
                • RoundedButtonStyle / CleanListBoxStyle reusable resources
              Safe to delete and replace with your own View.
    ════════════════════════════════════════════════════════════════════════
-->
<Window
    x:Class="RevitCloudKit.Views.Example.RevitCloudKitView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewModel="clr-namespace:RevitCloudKit.ViewModels.Example"
    xmlns:models="clr-namespace:RevitCloudKit.Models.Example"
    xmlns:db="clr-namespace:Autodesk.Revit.DB;assembly=RevitAPI"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModel:RevitCloudKitViewModel}"
    SnapsToDevicePixels="True"
    WindowStartupLocation="CenterScreen"
    Title="Materials"
    Height="540"
    Width="860"
    Loaded="OnLoaded">

    <Window.Resources>

        <!-- Rounded button: SkyBlue by default, dims when disabled -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#D0D7DE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox stripped of default chrome; selection highlighted in light blue -->
        <Style x:Key="CleanListBoxStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Margin="4,2">
                                        <ContentPresenter Margin="10,7"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F0F9FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E0F2FE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cloud library row: name + class label + per-row delete button -->
        <DataTemplate x:Key="CloudMaterialItemTemplate" DataType="{x:Type models:SupabaseMaterialModel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Name}"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <TextBlock Text="{Binding MaterialClass}"
                               Foreground="#6B7280"
                               FontSize="11"
                               Margin="0,1,0,0"/>
                </StackPanel>

                <Button x:Name="DeleteButton"
                        Grid.Column="1"
                        Content="×"
                        Width="22" Height="22"
                        Visibility="Collapsed"
                        Foreground="#EF4444"
                        Background="Transparent"
                        FontSize="17"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        ToolTip="Delete from cloud library"
                        Style="{StaticResource RoundedButtonStyle}"
                        Command="{Binding DataContext.DeleteCommand,
                                          RelativeSource={RelativeSource AncestorType=ListBox}}"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected,
                                               RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                             Value="True">
                    <Setter TargetName="DeleteButton" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Revit model row -->
        <DataTemplate x:Key="RevitMaterialItemTemplate" DataType="{x:Type db:Material}">
            <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold"
                           FontSize="13"/>
                <TextBlock Text="{Binding MaterialClass}"
                           Foreground="#6B7280"
                           FontSize="11"
                           Margin="0,1,0,0"/>
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Materials"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="SkyBlue"/>
            </StackPanel>

            <Button HorizontalAlignment="Right"
                    Content="Refresh"
                    Width="100" Height="34"
                    Background="SkyBlue"
                    Style="{StaticResource RoundedButtonStyle}"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- ── Two lists + transfer buttons ─────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Cloud library -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top"
                           Text="☁  Cloud Library"
                           FontWeight="SemiBold"
                           Foreground="#6B7280"
                           FontSize="12"
                           Margin="2,0,0,6"/>
                <Border CornerRadius="6"
                        BorderBrush="#D0D7DE"
                        BorderThickness="1">
                    <ListBox ItemsSource="{Binding CloudMaterials}"
                             SelectedItem="{Binding SelectedCloudMaterial}"
                             Style="{StaticResource CleanListBoxStyle}"
                             ItemTemplate="{StaticResource CloudMaterialItemTemplate}"/>
                </Border>
            </DockPanel>

            <!-- Centre: transfer buttons -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="44">
                <Button Content="→"
                        Height="44"
                        Background="SkyBlue"
                        FontSize="18"
                        Margin="0,0,0,10"
                        Style="{StaticResource RoundedButtonStyle}"
                        ToolTip="Import selected cloud material into the current model"
                        Command="{Binding ImportCommand}"/>
                <Button Content="←"
                        Height="44"
                        Background="SkyBlue"
                        FontSize="18"
                        Style="{StaticResource RoundedButtonStyle}"
                        ToolTip="Publish selected model material to the cloud library"
                        Command="{Binding PublishCommand}"/>
            </StackPanel>

            <!-- Right: Current model -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top"
                           Text="📐  Current Model"
                           FontWeight="SemiBold"
                           Foreground="#6B7280"
                           FontSize="12"
                           Margin="2,0,0,6"/>
                <Border CornerRadius="6"
                        BorderBrush="#D0D7DE"
                        BorderThickness="1">
                    <ListBox ItemsSource="{Binding RevitMaterials}"
                             SelectedItem="{Binding SelectedRevitMaterial}"
                             Style="{StaticResource CleanListBoxStyle}"
                             ItemTemplate="{StaticResource RevitMaterialItemTemplate}"/>
                </Border>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
