<Window x:Class="RevitCloudKit.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        SnapsToDevicePixels="True"
        xmlns:viewModel="clr-namespace:RevitCloudKit.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModel:LoginViewModel,
                                     IsDesignTimeCreatable=False}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="Login"
        Height="450" 
        Width="500">
    <Window.Resources>
        <Style x:Key="RoundedCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="16" Height="16" Margin="0,0,8,0">
                                <Border x:Name="CheckBorder"
                                        CornerRadius="4"
                                        BorderBrush="#9CA3AF"
                                        BorderThickness="1"
                                        Background="White"/>
                                <Path x:Name="CheckMark"
                                      Data="M 3 8 L 7 12 L 13 4"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="SkyBlue"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="SkyBlue"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <StackPanel Width="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Welcome"
                       Foreground="SkyBlue"
                       FontSize="24"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <Border CornerRadius="6"
                    BorderBrush="#D0D7DE"
                    BorderThickness="1"
                    Margin="0,0,0,16">
                <TextBox Height="38"
                         Padding="12,8"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalContentAlignment="Center"
                         ToolTip="Email"
                         Text="{Binding Email}"/>
            </Border>

            <Border CornerRadius="6"
                    BorderBrush="#D0D7DE"
                    BorderThickness="1">
                <TextBox Height="38"
                         Padding="12,8"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalContentAlignment="Center"
                         ToolTip="Email"
                         Text="{Binding Password}"/>
            </Border>

            <CheckBox Content="Remember me"
                      Margin="2,10,0,0"
                      Foreground="#6B7280"
                      IsChecked="{Binding RememberMe}"
                      Style="{StaticResource RoundedCheckBoxStyle}"/>

            <Border CornerRadius="6"
                    Background="SkyBlue"
                    Margin="0,12,0,0">
                <Button Content="Login"
                        Height="38"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Command="{Binding LoginCommand}"/>
            </Border>
        </StackPanel>

        <TextBlock Name="VersionText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,12"
                   Foreground="#6B7280"
                   Opacity="0.6"
                   FontSize="12"/>
    </Grid>
</Window>
